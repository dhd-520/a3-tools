<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net7.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>A3Tool.ico</ApplicationIcon>
    <AssemblyName>A3Tools</AssemblyName>
  </PropertyGroup>

  <!-- 为 Designer.cs 添加嵌套关系（SDK默认已包含，通过Update添加DependentUpon） -->
  <ItemGroup>
    <Compile Update="Forms\MainForm.Designer.cs">
      <DependentUpon>MainForm.cs</DependentUpon>
    </Compile>
    <Compile Update="Forms\AccountDialog.Designer.cs">
      <DependentUpon>AccountDialog.cs</DependentUpon>
    </Compile>
    <Compile Update="Forms\SettingsDialog.Designer.cs">
      <DependentUpon>SettingsDialog.cs</DependentUpon>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.SqlServer.SqlManagementObjects" Version="171.30.0" />
    <PackageReference Include="NPinyin" Version="0.2.6321.26573" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\A3Tools.Common\A3Tools.Common.csproj" />
  </ItemGroup>

  <!-- 插件目录 -->
  <ItemGroup>
    <None Update="Plugins\tools.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Plugins\A3Tools.Plugins.Default.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- 复制图标到输出目录（托盘图标用） -->
  <ItemGroup>
    <None Include="A3Tool.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
